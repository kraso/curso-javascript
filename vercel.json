{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "remix",
  "buildCommand": "npx remix vite:build",
  "outputDirectory": "build",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/html; charset=utf-8"
        }
      ]
    }
  ]
}
